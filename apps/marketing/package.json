{
    "name": "@dora/marketing",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.3.13",
    "scripts": {
        "dev": "bun --bun next dev",
        "seo": "tools/seo/run.sh",
        "seo:setup": "tools/seo/setup-ci.sh",
        "seo:prod": "tools/seo/index.sh",
        "build": "bun --bun next build",
        "postbuild": "tools/seo/build-audit.sh",
        "build:ci": "bun --bun next build",
        "start": "bun --bun next start",
        "typecheck": "bun --bun tsc --noEmit",
        "format": "bunx oxfmt .",
        "format:check": "bunx oxfmt --check .",
        "lint": "bunx oxlint .",
        "check": "bun run typecheck && bun run format:check && bun run lint && bun run build"
    },
    "dependencies": {
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.1",
        "geist": "^1.7.1",
        "lucide-react": "^1.17.0",
        "next": "16.2.4",
        "next-themes": "^0.4.6",
        "@remcostoeten/use-shortcut": "^2.3.0",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "swr": "^2.4.1",
        "three": "^0.184.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@types/node": "^22.16.5",
        "@types/react": "^19.2.6",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.1",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "postcss": "^8.5.15",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.8.3"
    }
}

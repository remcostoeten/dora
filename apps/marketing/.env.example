NEXT_PUBLIC_SITE_URL=https://doradb.app

# Analytics — enabled by default. Set NEXT_PUBLIC_ANALYTICS_ENABLED=false to disable.
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_PROJECT_ID=dora-landing
NEXT_PUBLIC_ANALYTICS_INGEST_URL=https://ingestion.remcostoeten.nl

# Supabase Management-API OAuth proxy (/api/oauth/supabase/*)
# -----------------------------------------------------------------------------
# Powers the desktop app's one-click "Connect with Supabase". The proxy holds
# the client secret (Supabase's Management API OAuth is a confidential client)
# and performs the code + refresh token exchanges; the desktop app never sees
# the secret. User project data never flows through here.
#
# Create the OAuth app: Supabase Dashboard -> your org -> Settings -> OAuth Apps
# Register exactly this redirect URI on it:
#   https://doradb.app/api/oauth/supabase/callback
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=

# Secret that encrypts + authenticates the short-lived OAuth `state` blob.
# Generate one with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Optional. Space-separated scopes, if your OAuth app needs them on the
# authorize request (otherwise the app's configured scopes are used).
# SUPABASE_OAUTH_SCOPES=

# Optional. Override the callback origin if it can't be derived from the request
# (behind a proxy, or for local dev). Must match the registered redirect URI origin.
# OAUTH_CALLBACK_ORIGIN=http://localhost:3000

# Analytics
# Set to true in production builds that should send telemetry.
VITE_ANALYTICS_ENABLED=false

# Enables SDK/provider debug logging.
VITE_ANALYTICS_DEBUG=false

# First-party @remcostoeten/analytics configuration.
VITE_REMCO_ANALYTICS_ENABLED=true
VITE_ANALYTICS_PROJECT_ID=dora-desktop
VITE_ANALYTICS_INGEST_URL=https://ingestion.remcostoeten.nl

# Optional Vercel Analytics provider.
VITE_VERCEL_ANALYTICS_ENABLED=false

# Optional: also forward custom product events to Vercel's `track` API.
VITE_VERCEL_ANALYTICS_EVENTS=false

# Supabase integration ("Connect via provider" in the connection dialog).
#
# Two ways to connect:
#   1. One-click OAuth ("Connect with Supabase") — opens the browser, approve,
#      done. The secret-requiring token exchange runs through a hosted proxy in
#      the marketing app (see apps/marketing/.env.example).
#   2. Personal access token fallback — paste a token from
#      supabase.com/dashboard/account/tokens. No server needed.
# Either way the resulting tokens are encrypted and stored on-device.
#
# DORA_OAUTH_PROXY_BASE overrides the OAuth proxy base URL (defaults to the
# production marketing domain compiled into supabase.rs). Set this for local dev
# when running the marketing app via `bun dev`:
# DORA_OAUTH_PROXY_BASE=http://localhost:3000

# Analytics
# Set to true in production builds that should send telemetry.
VITE_ANALYTICS_ENABLED=false

# Enables SDK/provider debug logging.
VITE_ANALYTICS_DEBUG=false

# First-party @remcostoeten/analytics configuration.
VITE_REMCO_ANALYTICS_ENABLED=true
VITE_ANALYTICS_PROJECT_ID=dora-desktop
VITE_ANALYTICS_INGEST_URL=https://analytics.remcostoeten.nl

# Optional Vercel Analytics provider.
VITE_VERCEL_ANALYTICS_ENABLED=false

# Optional: also forward custom product events to Vercel's `track` API.
VITE_VERCEL_ANALYTICS_EVENTS=false
